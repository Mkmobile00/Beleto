    CONSTRAINT sliders_is_video_check CHECK (((is_video)::text = ANY ((ARRAY['no'::character varying, 'yes'::character varying])::text[]))),
    CONSTRAINT sliders_status_check CHECK (((status)::text = ANY ((ARRAY['active'::character varying, 'inactive'::character varying])::text[]))),
